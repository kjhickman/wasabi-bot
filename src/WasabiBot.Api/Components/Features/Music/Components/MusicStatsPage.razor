@namespace WasabiBot.Api.Components.Features.Music
@using WasabiBot.Api.Components.Shared
@using WasabiBot.Api.Features.Music

<article class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4" aria-labelledby="music-most-played-heading">
    <header class="space-y-2.5">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Guild Stats</p>
        <h2 id="music-most-played-heading">Most played in @(Session?.Channel.GuildName ?? "this guild")</h2>
    </header>

    @if (Session is null)
    {
        <p id="music-most-played-empty">Join the bot in a voice channel to load guild-specific listening stats.</p>
    }
    else if (IsLoadingMostPlayed)
    {
        <p id="music-most-played-loading">Loading most played songs...</p>
    }
    else if (MostPlayedTracks.Count == 0)
    {
        <p id="music-most-played-empty">No songs have been tracked in this guild yet.</p>
    }
    else
    {
        <ol id="music-most-played-list" class="music-stats-list">
            @for (var index = 0; index < MostPlayedTracks.Count; index++)
            {
                var track = MostPlayedTracks[index];
                <li class="music-stats-item">
                    <span class="music-stats-item__rank">@(index + 1)</span>
                    <div class="music-search-result-item__row">
                        <div class="music-search-result-item__content">
                            @if (!string.IsNullOrWhiteSpace(track.ArtworkUrl))
                            {
                                <img class="music-search-result-item__artwork" src="@track.ArtworkUrl" alt="Artwork for @track.Title" />
                            }
                            else
                            {
                                <div class="music-artwork-placeholder music-search-result-item__artwork" aria-hidden="true">
                                    <LucideIcon Name="LucideIconName.Disc3" Class="size-7" />
                                </div>
                            }

                            <div class="music-stats-item__body">
                                <strong>@track.Title</strong>
                                <span>by @track.Artist</span>
                                <div class="music-now-playing__meta-row">
                                    <span class="music-track-meta">Played @track.PlayCount time(s)</span>
                                </div>
                            </div>
                        </div>

                        <div class="music-search-result-item__actions music-search-result-item__actions--right">
                            <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnQueueTrack.InvokeAsync(track)">Add to queue</button>
                            <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnPlayTrackNext.InvokeAsync(track)">Play next</button>
                            <button class="btn btn-sm @(track.IsFavorited ? "btn-primary" : "btn-outline")" type="button" disabled="@IsSubmittingAction" @onclick="() => OnSaveTrackFavorite.InvokeAsync(track)" aria-label="@(track.IsFavorited ? $"Remove {track.Title} from favorites" : $"Favorite {track.Title}")">
                                <LucideIcon Name="@(track.IsFavorited ? LucideIconName.HeartMinus : LucideIconName.HeartPlus)" Class="size-4" />
                            </button>
                        </div>
                    </div>
                </li>
            }
        </ol>
    }
</article>

@code {
    [Parameter]
    public ActiveMusicSession? Session { get; set; }

    [Parameter]
    public bool IsLoadingMostPlayed { get; set; }

    [Parameter]
    public IReadOnlyList<GuildTopTrackSummary> MostPlayedTracks { get; set; } = [];

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public bool HasSharedSession { get; set; }

    [Parameter]
    public EventCallback<GuildTopTrackSummary> OnQueueTrack { get; set; }

    [Parameter]
    public EventCallback<GuildTopTrackSummary> OnPlayTrackNext { get; set; }

    [Parameter]
    public EventCallback<GuildTopTrackSummary> OnSaveTrackFavorite { get; set; }
}
