@namespace WasabiBot.Api.Components.Features.Music
@page "/music"
@attribute [Authorize(Policy = "DiscordGuildMember")]
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <SignedOutPrompt SectionId="music-unauthenticated"
                     HeadingId="music-signin-heading"
                     Heading="Sign in to view live music"
                     Description="See the current queue and now playing state for the voice channel you're sharing with Wasabi Bot."
                     LinkId="music-login-link"
                     Href="/login-discord?returnUrl=%2Fmusic" />
}
else if (!HasGuildAccess)
{
    <GuildAccessRequired />
}
else
{
    <section id="music-page" class="music-page stack-lg" aria-labelledby="music-page-heading">
        <header class="music-page__header stack-sm">
            <p class="eyebrow">Live Queue</p>
            <h1 id="music-page-heading">Music Dashboard</h1>
            <p class="section-copy">Live queue view for the voice channel you're currently sharing with Wasabi Bot.</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(LoadError))
        {
            <article id="music-error" class="surface-card stack-sm" aria-live="polite">
                <h2>Dashboard unavailable</h2>
                <p>@LoadError</p>
            </article>
        }
        else if (IsLoading)
        {
            <article id="music-loading" class="surface-card stack-sm" aria-live="polite">
                <h2>Loading live queue</h2>
                <p>Checking the voice channel you're currently sharing with Wasabi Bot.</p>
            </article>
        }
        else if (Session is null)
        {
            <article id="music-empty-state" class="surface-card stack-sm" aria-live="polite">
                <h2>Join a voice channel with Wasabi Bot</h2>
                <p>Once you're in the same voice channel as the bot, this page will show the live queue and current track.</p>
            </article>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(ActionMessage))
            {
                <article id="music-action-message" class="surface-card stack-sm" aria-live="polite">
                    <h2>@(ActionIsError ? "Action blocked" : "Action completed")</h2>
                    <p>@ActionMessage</p>
                </article>
            }

            <div class="music-page__meta" aria-label="Current session context">
                <span id="music-guild-name" class="music-pill">@Session.Channel.GuildName</span>
                <span id="music-channel-name" class="music-pill">#@Session.Channel.VoiceChannelName</span>
                <span id="music-playback-state" class="music-pill">@Session.PlaybackState</span>
            </div>

            <section id="music-controls" class="music-controls" aria-label="Playback controls">
                <button id="music-toggle-pause"
                        type="button"
                        disabled="@IsSubmittingAction"
                        @onclick="TogglePauseAsync">
                    @(Session.PlaybackState == "Paused" ? "Resume" : "Pause")
                </button>
                <button id="music-skip"
                        type="button"
                        disabled="@IsSubmittingAction"
                        @onclick="SkipAsync">
                    Skip
                </button>
                <button id="music-stop"
                        type="button"
                        disabled="@IsSubmittingAction"
                        @onclick="StopAsync">
                    Stop
                </button>
            </section>

            <article class="surface-card stack-md" aria-labelledby="music-search-heading">
                <header class="stack-sm">
                    <p class="eyebrow">Search</p>
                    <h2 id="music-search-heading">Find songs and radio</h2>
                </header>

                <div class="music-search-form">
                    <label class="music-search-form__field" for="music-search-query">
                        <span class="sr-only">Search query</span>
                        <input id="music-search-query"
                               type="search"
                               placeholder="Search SoundCloud songs or radio stations"
                               @bind="SearchQuery"
                               @bind:event="oninput" />
                    </label>
                    <button id="music-search-submit"
                            type="button"
                            disabled="@IsSearching"
                            @onclick="SearchAsync">
                        @(IsSearching ? "Searching..." : "Search")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(SearchError))
                {
                    <p id="music-search-error">@SearchError</p>
                }
                else if (SearchResults is not null)
                {
                    <div class="music-search-results">
                        <section class="stack-sm" aria-labelledby="music-song-results-heading">
                            <h3 id="music-song-results-heading">Songs</h3>
                            @if (SearchResults.Songs.Count == 0)
                            {
                                <p id="music-song-results-empty">No SoundCloud songs found.</p>
                            }
                            else
                            {
                                <ul id="music-song-results" class="music-search-result-list">
                                    @foreach (var song in SearchResults.Songs)
                                    {
                                        <li class="music-search-result-item">
                                            <div class="music-search-result-item__content">
                                                @if (!string.IsNullOrWhiteSpace(song.ArtworkUrl))
                                                {
                                                    <img class="music-search-result-item__artwork" src="@song.ArtworkUrl" alt="Artwork for @song.Title" />
                                                }
                                                <div class="music-search-result-item__details">
                                                    <strong>@song.Title</strong>
                                                    <span>by @song.Author</span>
                                                    <div class="music-now-playing__meta-row">
                                                        <span class="music-track-meta">@song.DurationText</span>
                                                        @if (!string.IsNullOrWhiteSpace(song.SourceName))
                                                        {
                                                            <span class="music-track-meta">@FormatSourceName(song.SourceName)</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="music-search-result-item__actions">
                                                <button type="button" disabled="@IsSubmittingAction" @onclick="() => QueueSongAsync(song)">Add to queue</button>
                                                <button type="button" disabled="@IsSubmittingAction" @onclick="() => PlaySongNextAsync(song)">Play next</button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </section>

                        <section class="stack-sm" aria-labelledby="music-radio-results-heading">
                            <h3 id="music-radio-results-heading">Radio stations</h3>
                            @if (SearchResults.Stations.Count == 0)
                            {
                                <p id="music-radio-results-empty">No radio stations found.</p>
                            }
                            else
                            {
                                <ul id="music-radio-results" class="music-search-result-list">
                                    @foreach (var station in SearchResults.Stations)
                                    {
                                        <li class="music-search-result-item">
                                            <div class="music-search-result-item__content">
                                                @if (!string.IsNullOrWhiteSpace(station.ArtworkUrl))
                                                {
                                                    <img class="music-search-result-item__artwork" src="@station.ArtworkUrl" alt="Artwork for @station.Name" />
                                                }
                                                <div class="music-search-result-item__details">
                                                    <strong>@station.Name</strong>
                                                    @if (!string.IsNullOrWhiteSpace(station.Country))
                                                    {
                                                        <span>@station.Country</span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(station.Tags))
                                                    {
                                                        <span class="music-track-meta">@FormatStationTags(station.Tags)</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="music-search-result-item__actions">
                                                <button type="button" disabled="@IsSubmittingAction" @onclick="() => QueueStationAsync(station)">Add to queue</button>
                                                <button type="button" disabled="@IsSubmittingAction" @onclick="() => PlayStationNextAsync(station)">Play next</button>
                                                @if (!string.IsNullOrWhiteSpace(station.HomepageUrl))
                                                {
                                                    <a href="@station.HomepageUrl" target="_blank" rel="noopener noreferrer">Homepage</a>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </section>
                    </div>
                }
            </article>

            <div class="music-grid">
                <article class="surface-card stack-md" aria-labelledby="music-now-playing-heading">
                    <header class="stack-sm">
                        <p class="eyebrow">Now Playing</p>
                        <h2 id="music-now-playing-heading">Current track</h2>
                    </header>

                    @if (Session.NowPlaying is null)
                    {
                        <p id="music-now-playing-empty">Nothing is playing right now.</p>
                    }
                    else
                    {
                        <div class="music-now-playing">
                            @if (!string.IsNullOrWhiteSpace(Session.NowPlaying.ArtworkUrl))
                            {
                                <img id="music-artwork"
                                     class="music-now-playing__artwork"
                                     src="@Session.NowPlaying.ArtworkUrl"
                                     alt="Album artwork for @Session.NowPlaying.Title" />
                            }

                            <div id="music-now-playing-track" class="stack-xs music-now-playing__details">
                                <strong>@Session.NowPlaying.Title</strong>
                                @if (!Session.NowPlaying.IsRadio)
                                {
                                    <span>by @Session.NowPlaying.Author</span>
                                }

                                <div class="music-now-playing__meta-row">
                                    <span class="music-track-meta">@Session.NowPlaying.DurationText</span>
                                    @if (!string.IsNullOrWhiteSpace(Session.NowPlaying.SourceName))
                                    {
                                        <span id="music-source-name" class="music-track-meta">@FormatSourceName(Session.NowPlaying.SourceName)</span>
                                    }
                                </div>

                                @if (Session.Progress is not null && Session.NowPlaying.Duration is { } duration)
                                {
                                    <div id="music-progress" class="music-progress stack-xs" aria-label="Playback progress">
                                        <progress value="@Session.Progress.Position.TotalSeconds" max="@duration.TotalSeconds"></progress>
                                        <div class="music-progress__times">
                                            <span id="music-progress-position">@Session.Progress.PositionText</span>
                                            <span id="music-progress-duration">@Session.NowPlaying.DurationText</span>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(Session.NowPlaying.SourceUrl))
                                {
                                    <p class="music-now-playing__source-link">
                                        <a id="music-source-link" href="@Session.NowPlaying.SourceUrl" target="_blank" rel="noopener noreferrer">Open source</a>
                                    </p>
                                }
                            </div>
                        </div>
                    }
                </article>

                <article class="surface-card stack-md" aria-labelledby="music-queue-heading">
                    <header class="stack-sm">
                        <p class="eyebrow">Queue</p>
                        <h2 id="music-queue-heading">Up next</h2>
                    </header>

                    @if (Session.Queue.Count == 0)
                    {
                        <p id="music-queue-empty">The queue is empty.</p>
                    }
                    else
                    {
                        <ol id="music-queue-list" class="music-queue-list">
                            @foreach (var item in Session.Queue)
                            {
                                <li class="music-queue-item">
                                    <div class="music-queue-item__body">
                                        <strong>@item.Track.Title</strong>
                                        @if (!item.Track.IsRadio)
                                        {
                                            <span>by @item.Track.Author</span>
                                        }
                                    </div>
                                    <span class="music-track-meta">@item.Track.DurationText</span>
                                </li>
                            }
                        </ol>
                    }
                </article>
            </div>
        }
    </section>
}

@code {
    private static string FormatSourceName(string sourceName)
    {
        return sourceName.ToLowerInvariant() switch
        {
            "scsearch" => "SoundCloud",
            "soundcloud" => "SoundCloud",
            "http" => "Direct stream",
            _ => sourceName
        };
    }

    private static string FormatStationTags(string tags)
    {
        var parts = tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Join(" • ", parts.Take(3));
    }
}
