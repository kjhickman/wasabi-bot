@namespace WasabiBot.Api.Components.Features.Credentials
<dialog id="credentials-create-modal" class="modal modal-open" open>
    <div class="modal-box space-y-4">
        <header class="space-y-2">
            <a class="link link-hover text-sm" href="/creds" rel="prev">Back</a>
            <h2 id="credentials-create-heading">Create a credential</h2>
        </header>

        <EditForm id="credentials-create-form" class="space-y-4" Model="Model" OnSubmit="OnSubmit" FormName="create-credential" Enhance>
            <label class="block text-sm font-medium" for="credential-name-input">Name</label>
            <input id="credential-name-input"
                   class="input input-bordered w-full"
                   name="CreateCredentialForm.Name"
                   @bind="Model.Name"
                   maxlength="100"
                   autocomplete="off"
                   placeholder="My api creds"
                   required />
            <p id="credential-name-help" class="text-sm text-base-content/70">1 to 100 characters. Control characters are not allowed.</p>

            @if (!string.IsNullOrWhiteSpace(CreateCredentialError))
            {
                <p id="credentials-form-error" class="rounded-box border border-error/40 bg-error/10 px-4 py-3 text-sm text-error" role="alert">@CreateCredentialError</p>
            }

            <footer class="modal-action">
                <a class="btn btn-ghost" href="/creds">Cancel</a>
                <button id="create-credential-button" class="btn btn-primary" type="submit">Create credential</button>
            </footer>
        </EditForm>
    </div>
</dialog>

@code {
    [Parameter, EditorRequired]
    public required CredentialsCreateCredentialFormInput Model { get; set; }

    [Parameter]
    public string? CreateCredentialError { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }
}
