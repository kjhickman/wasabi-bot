@namespace WasabiBot.Api.Components.Features.Credentials
@using System.Globalization
@using WasabiBot.Api.Infrastructure.Auth

<article class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4">
    <header>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h2 id="credentials-list-heading">Your API Credentials</h2>

            <div>
                <a id="credentials-create-open-button" class="btn btn-primary btn-sm" href="/creds?modal=create">Create</a>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(PageError))
    {
        <p id="credentials-page-error" class="rounded-box border border-error/40 bg-error/10 px-4 py-3 text-sm text-error" role="alert">@PageError</p>
    }

    <div class="overflow-x-auto">
        <table id="credentials-table" class="table table-zebra">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Client ID</th>
                    <th scope="col">Created</th>
                    <th scope="col">Last Used</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody id="credentials-list">
                @if (CredentialRows.Count == 0)
                {
                    <tr>
                        <td colspan="5">Create a credential to start exchanging for API tokens.</td>
                    </tr>
                }
                else
                {
                    @foreach (var credential in CredentialRows)
                    {
                        <tr>
                            <td>@credential.Name</td>
                            <td>
                                <code class="inline-block rounded-box bg-base-200 px-2 py-1 text-sm break-all">@credential.ClientId</code>
                            </td>
                            <td>@FormatTimestamp(credential.CreatedAt)</td>
                            <td>@FormatTimestamp(credential.LastUsedAt)</td>
                            <td>
                                <div class="flex flex-wrap gap-2">
                                    <a class="btn btn-ghost btn-xs" href="/creds?modal=regenerate&id=@credential.Id">Regenerate</a>
                                    <a class="btn btn-error btn-xs btn-outline" href="/creds?modal=delete&id=@credential.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public required IReadOnlyList<ApiCredentialSummary> CredentialRows { get; set; }

    [Parameter]
    public string? PageError { get; set; }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "Never";
        }

        return value.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt", CultureInfo.InvariantCulture);
    }
}
