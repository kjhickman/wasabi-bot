@namespace WasabiBot.Api.Components.Features.Credentials
<dialog id="credentials-confirm-modal" class="credentials-modal" open>
    <article>
        <header>
            <a aria-label="Close" href="/creds" rel="prev"></a>
            <h2 id="credentials-confirm-title">@ConfirmTitle</h2>
        </header>

        <p id="credentials-confirm-message" class="credentials-copy">@ConfirmMessage</p>

        @if (!string.IsNullOrWhiteSpace(ConfirmError))
        {
            <p id="credentials-confirm-error" class="credentials-error" role="alert">@ConfirmError</p>
        }

        <EditForm Model="Model" OnSubmit="OnSubmit" FormName="confirm-credential" Enhance>
            <footer class="credentials-modal__actions">
                <a class="secondary" href="/creds" role="button">Cancel</a>
                <button type="submit" class="@(IsDeleteAction ? "contrast" : null)">@ConfirmButtonText</button>
            </footer>
        </EditForm>
    </article>
</dialog>

@code {
    [Parameter, EditorRequired]
    public required CredentialsConfirmCredentialFormInput Model { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmTitle { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmMessage { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmButtonText { get; set; }

    [Parameter]
    public bool IsDeleteAction { get; set; }

    [Parameter]
    public string? ConfirmError { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }
}
