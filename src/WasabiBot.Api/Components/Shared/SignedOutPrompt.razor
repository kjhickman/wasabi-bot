<section id="@SectionId" class="flex min-h-[calc(100vh-14rem)] items-center justify-center" aria-labelledby="@HeadingId">
    <div class="surface-card mx-auto max-w-2xl text-center">
        <h1 id="@HeadingId" class="text-3xl font-semibold tracking-tight md:text-4xl">@Heading</h1>
        <p class="mt-4 text-base leading-7 text-base-content/70">@Description</p>
        <p>
            <a id="@LinkId" class="btn btn-primary mt-6" href="@Href" autofocus>@LinkText</a>
        </p>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public required string SectionId { get; set; }

    [Parameter, EditorRequired]
    public required string HeadingId { get; set; }

    [Parameter, EditorRequired]
    public required string Heading { get; set; }

    [Parameter, EditorRequired]
    public required string Description { get; set; }

    [Parameter, EditorRequired]
    public required string LinkId { get; set; }

    [Parameter]
    public string Href { get; set; } = "/login-discord";

    [Parameter]
    public string LinkText { get; set; } = "Sign in with Discord";
}
