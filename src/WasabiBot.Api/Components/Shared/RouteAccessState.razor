@namespace WasabiBot.Api.Components.Shared
@inject NavigationManager NavigationManager

<AuthorizeView>
    <Authorized>
        <GuildAccessRequired />
    </Authorized>
    <NotAuthorized>
        <SignedOutPrompt SectionId="unauthenticated"
                         HeadingId="unauthenticated-heading"
                         Heading="Sign in to Wasabi Bot"
                         Description="Generate API tokens and manage upcoming bot features from one place."
                         LinkId="login-link"
                         Href="@GetLoginHref()" />
    </NotAuthorized>
</AuthorizeView>

@code {
    private string GetLoginHref()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (string.IsNullOrWhiteSpace(relativePath))
        {
            return "/login-discord";
        }

        return $"/login-discord?returnUrl=/{Uri.EscapeDataString(relativePath)}";
    }
}
