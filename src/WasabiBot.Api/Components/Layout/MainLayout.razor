@inherits LayoutComponentBase

<div class="min-h-screen bg-base-200">
    <header class="border-b border-base-300 bg-base-100/90 backdrop-blur">
        <nav class="navbar mx-auto max-w-6xl gap-3 px-4 md:px-6" aria-label="Primary navigation">
            <div class="flex-1">
                <a class="btn btn-ghost px-2 text-lg font-semibold normal-case" href="/" aria-label="Wasabi Bot home">
                    <strong>Wasabi Bot</strong>
                </a>
            </div>

            <AuthorizeView>
                <Authorized Context="authState">
                    @{
                        var displayName = authState.User.DisplayName;
                        var avatarUrl = authState.User.DiscordAvatarUrl;
                        var avatarInitial = displayName[..1].ToUpperInvariant();
                    }

                    <div class="flex flex-none items-center gap-2">
                        <NavLink id="nav-link-music" class="btn btn-ghost btn-sm" href="/music" Match="NavLinkMatch.Prefix" ActiveClass="btn-active">Music room</NavLink>
                        <NavLink id="nav-link-creds" class="btn btn-ghost btn-sm" href="/creds" Match="NavLinkMatch.Prefix" ActiveClass="btn-active">API access</NavLink>

                        <div class="dropdown dropdown-end">
                            <button id="account-menu-button"
                                    type="button"
                                    class="btn btn-outline h-auto min-h-0 rounded-full border-base-300 bg-base-100 pl-2 pr-3 py-1.5 normal-case shadow-sm hover:bg-base-200"
                                    aria-haspopup="menu">
                                @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                {
                                    <img id="header-user-avatar" class="size-10 rounded-full object-cover" src="@avatarUrl" alt="" />
                                }
                                else
                                {
                                    <span id="header-user-avatar-fallback" class="flex size-10 items-center justify-center rounded-full border border-base-300 bg-base-100 text-sm font-semibold" aria-hidden="true">@avatarInitial</span>
                                }

                                <span id="header-user-name" class="ml-1.5 text-sm font-medium">@displayName</span>
                            </button>

                            <div id="account-menu-panel"
                                 tabindex="-1"
                                 class="dropdown-content z-10 mt-3 w-64 rounded-box border border-base-300 bg-base-100 p-3 shadow-lg"
                                 role="menu"
                                 aria-labelledby="account-menu-button">
                                <fieldset class="stack-sm">
                                    <legend class="text-xs font-semibold uppercase tracking-[0.2em] text-base-content/60">Theme</legend>
                                    <div class="join w-full">
                                        <input id="theme-preference-light"
                                               class="btn btn-sm join-item flex-1"
                                               type="radio"
                                               name="theme-preference"
                                               value="light"
                                               aria-label="Light"
                                               data-theme-preference />
                                        <input id="theme-preference-dark"
                                               class="btn btn-sm join-item flex-1"
                                               type="radio"
                                               name="theme-preference"
                                               value="dark"
                                               aria-label="Dark"
                                               data-theme-preference />
                                        <input id="theme-preference-system"
                                               class="btn btn-sm join-item flex-1"
                                               type="radio"
                                               name="theme-preference"
                                               value="system"
                                               aria-label="System"
                                               data-theme-preference />
                                    </div>
                                </fieldset>

                                <form class="mt-3 border-t border-base-300 pt-3" action="/logout" method="post">
                                    <AntiforgeryToken />
                                    <button id="logout-button" class="btn btn-ghost btn-sm w-full justify-start gap-2" type="submit">
                                        <LucideIcon Name="LucideIconName.LogOut" Class="size-4 shrink-0" />
                                        <span>Log out</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>
    </header>

    <main class="mx-auto w-full max-w-6xl px-4 py-8 md:px-6 md:py-10">
        <div class="space-y-6">
            @Body
        </div>
    </main>
</div>
