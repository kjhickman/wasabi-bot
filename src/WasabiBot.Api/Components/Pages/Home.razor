@page "/"

<PageTitle>@PageTitleText - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <SignedOutPrompt SectionId="unauthenticated"
                     HeadingId="unauthenticated-heading"
                     Heading="Sign in to Wasabi Bot"
                     Description="Generate API tokens and manage upcoming bot features from one place."
                     LinkId="login-link" />
}
else if (!HasGuildAccess)
{
    <GuildAccessRequired />
}
else
{
    <section id="authenticated" class="dashboard-stack" aria-labelledby="authenticated-heading">
        <header class="page-heading">
            <h1 id="authenticated-heading">Hello, <span id="user-greeting">@DisplayName</span></h1>
        </header>

        <div class="dashboard-grid">
            <article class="surface-card surface-card--accent stack-md" aria-labelledby="api-creds-heading">
                <header class="stack-sm">
                    <p class="eyebrow">Access</p>
                    <h2 id="api-creds-heading">Get API Access</h2>
                    <p>Create or manage credentials to gain access to the Wasabi Bot API.</p>
                </header>

                <section class="stack-sm">
                    <p class="section-copy">Need the endpoint reference? <a id="docs-link" href="/scalar/v1" target="_blank" rel="noopener noreferrer">Open API docs</a>.</p>
                    <p>
                        <a id="creds-link" href="/creds" role="button">Open creds</a>
                    </p>
                </section>
            </article>

            <article class="surface-card placeholder-card stack-md" aria-labelledby="music-heading">
                <header class="stack-sm">
                    <p class="eyebrow">Soon</p>
                    <h2 id="music-heading">Music</h2>
                </header>
                <p>Queue management, now playing state, and player controls can slot in here without changing the shell again.</p>
                <p class="placeholder-card__status">Coming soon</p>
            </article>

            <article class="surface-card placeholder-card stack-md" aria-labelledby="stats-heading">
                <header class="stack-sm">
                    <p class="eyebrow">Soon</p>
                    <h2 id="stats-heading">Stats</h2>
                </header>
                <p>Interaction counts, activity summaries, and quick operational views can live here once the data surface expands.</p>
                <p class="placeholder-card__status">Coming soon</p>
            </article>
        </div>
    </section>
}
