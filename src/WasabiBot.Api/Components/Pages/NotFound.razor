@page "/not-found"

<PageTitle>Not Found - Wasabi Bot</PageTitle>

<section class="flex min-h-[calc(100vh-14rem)] items-center justify-center" aria-labelledby="not-found-heading">
    <article class="surface-card mx-auto max-w-2xl text-center">
        <header class="space-y-2">
            <p class="eyebrow">404</p>
            <h1 id="not-found-heading" class="text-3xl font-semibold tracking-tight md:text-4xl">This page does not exist.</h1>
        </header>
        <p class="mt-4 text-base leading-7 text-base-content/70">The route may have moved, or it might be a page that has not been built yet.</p>
        <p class="mt-6">
            <a class="btn btn-primary" href="/">Back to home</a>
        </p>
    </article>
</section>
