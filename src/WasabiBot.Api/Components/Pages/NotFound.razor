@page "/not-found"

<PageTitle>Not Found - Wasabi Bot</PageTitle>

<section class="empty-state" aria-labelledby="not-found-heading">
    <article class="surface-card surface-card--hero stack-md">
        <header class="stack-sm">
            <p class="eyebrow">404</p>
            <h1 id="not-found-heading">This page does not exist.</h1>
        </header>
        <p>The route may have moved, or it might be a page that has not been built yet.</p>
        <p>
            <a href="/" role="button">Back to home</a>
        </p>
    </article>
</section>
