<article class="surface-card surface-card--accent stack-md" aria-labelledby="token-generator-heading">
    <header class="stack-sm">
        <p class="eyebrow">Access</p>
        <h2 id="token-generator-heading">Token Generator</h2>
        <p>Generate a short-lived token for the Wasabi Bot API. Tokens currently last 1 hour.</p>
    </header>

    <section class="token-panel stack-sm">
        <button id="generate-token-button"
                type="button"
                class="token-action-button"
                data-token-endpoint="/api/v1/token"
                data-tooltip="Generate and copy"
                data-placement="bottom"
                data-generate-token-button>
            Generate and copy token
        </button>

        <p class="token-help">Need the endpoint reference? <a id="docs-link" href="/scalar/v1" target="_blank" rel="noopener noreferrer">Open API docs</a>.</p>
    </section>
</article>
