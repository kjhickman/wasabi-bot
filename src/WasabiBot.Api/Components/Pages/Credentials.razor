@page "/creds"

<PageTitle>@(IsAuthenticated ? "API Credentials" : "Sign In") - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <section id="credentials-unauthenticated" class="landing-signin" aria-labelledby="credentials-signin-heading">
        <div class="landing-signin__content stack-md">
            <h1 id="credentials-signin-heading">Sign in to manage API credentials</h1>
            <p class="section-copy">Create client credentials for automation, rotate secrets, and revoke old access without leaving the dashboard.</p>
            <p>
                <a id="credentials-login-link" href="/auth/login-discord" role="button" autofocus>Sign in with Discord</a>
            </p>
        </div>
    </section>
}
else
{
    <section id="credentials-page"
             class="credentials-page stack-lg"
             aria-label="Credentials">
        @if (!string.IsNullOrWhiteSpace(UrlReplacementPath))
        {
            <span hidden data-replace-url="@UrlReplacementPath"></span>
        }

        <CredentialsListCard CredentialRows="CredentialRows" PageError="@PageError" />

        @if (ShowCreateModal)
        {
            <CredentialsCreateDialog Model="CreateCredentialForm"
                                     CreateCredentialError="@CreateCredentialError"
                                     OnSubmit="HandleCreateSubmit" />
        }

        @if (ShowConfirmModal)
        {
            <CredentialsConfirmDialog Model="ConfirmCredentialForm"
                                      ConfirmTitle="@ConfirmTitle"
                                      ConfirmMessage="@ConfirmMessage"
                                      ConfirmButtonText="@ConfirmButtonText"
                                      IsDeleteAction="@(CurrentConfirmAction == PendingCredentialAction.Delete)"
                                      ConfirmError="@ConfirmError"
                                      OnSubmit="HandleConfirmSubmit" />
        }

        @if (IssuedCredential is not null)
        {
            <IssuedCredentialDialog IssuedCredential="IssuedCredential" />
        }
    </section>
}
