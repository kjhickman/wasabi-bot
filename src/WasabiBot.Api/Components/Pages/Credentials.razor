@page "/creds"

<PageTitle>@(IsAuthenticated ? "API Credentials" : "Sign In") - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <section id="credentials-unauthenticated" class="landing-signin" aria-labelledby="credentials-signin-heading">
        <div class="landing-signin__content stack-md">
            <h1 id="credentials-signin-heading">Sign in to manage API credentials</h1>
            <p class="section-copy">Create client credentials for automation, rotate secrets, and revoke old access without leaving the dashboard.</p>
            <p>
                <a id="credentials-login-link" href="/auth/login-discord" role="button" autofocus>Sign in with Discord</a>
            </p>
        </div>
    </section>
}
else
{
    <section id="credentials-page"
             class="credentials-page stack-lg"
             aria-labelledby="credentials-heading"
             data-credentials-page
             data-list-endpoint="/api/v1/creds"
             data-create-endpoint="/api/v1/creds"
             data-delete-template="/api/v1/creds/__id__"
             data-regenerate-template="/api/v1/creds/__id__/regenerate-secret">
        <header class="page-heading stack-sm">
            <p class="eyebrow">Access</p>
            <h1 id="credentials-heading">API Credentials</h1>
            <p class="section-copy">Create durable client credentials for scripts and services, then exchange them for short-lived access tokens through <code>/oauth/token</code>.</p>
        </header>

        <div class="credentials-layout">
            <article class="surface-card surface-card--accent stack-md credentials-create-card">
                <header class="stack-sm">
                    <h2 id="credentials-create-heading">Create a credential</h2>
                    <p class="credentials-copy">Give each integration its own name so you can rotate or revoke access without guessing which client is which.</p>
                </header>

                <form id="credentials-create-form" class="stack-sm" data-credentials-create-form novalidate>
                    <label for="credential-name-input">Name</label>
                    <input id="credential-name-input"
                           name="name"
                           type="text"
                           maxlength="100"
                           autocomplete="off"
                           placeholder="My api creds"
                           required
                           data-credentials-name-input />
                    <p id="credential-name-help" class="credentials-help">1 to 100 characters. Control characters are not allowed.</p>
                    <p id="credentials-form-error" class="credentials-error" role="alert" hidden data-credentials-form-error></p>
                    <button id="create-credential-button" type="submit" data-credentials-create-button>Create credential</button>
                </form>
            </article>

            <article class="surface-card stack-md credentials-secret-card" id="credentials-secret-panel" hidden data-credentials-secret-panel>
                <header class="stack-sm">
                    <p class="eyebrow">One Time</p>
                    <h2 id="credentials-secret-heading">Copy this secret now</h2>
                    <p class="credentials-copy">You will only see this secret once. If you lose it, regenerate the secret for this credential.</p>
                </header>

                <div class="credentials-secret-grid">
                    <div class="credentials-secret-block stack-sm">
                        <span class="credentials-label">Client ID</span>
                        <code id="credentials-issued-client-id" data-credentials-issued-client-id></code>
                        <button type="button" class="secondary outline" data-copy-issued-client-id>Copy client ID</button>
                    </div>

                    <div class="credentials-secret-block stack-sm">
                        <span class="credentials-label">Client Secret</span>
                        <code id="credentials-issued-client-secret" data-credentials-issued-client-secret></code>
                        <button type="button" class="secondary" data-copy-issued-client-secret>Copy client secret</button>
                    </div>
                </div>
            </article>
        </div>

        <article class="surface-card stack-md credentials-list-card">
            <header class="stack-sm">
                <div class="credentials-list-heading">
                    <div class="stack-sm">
                        <h2 id="credentials-list-heading">Your credentials</h2>
                        <p class="credentials-copy">Each credential maps back to your Discord identity when it exchanges for an access token.</p>
                    </div>

                    <button id="credentials-refresh-button" type="button" class="secondary outline" data-credentials-refresh-button>Refresh</button>
                </div>
            </header>

            <p id="credentials-list-feedback" class="credentials-help" data-credentials-list-feedback>Loading credentials...</p>
            <div id="credentials-list" class="credentials-list" data-credentials-list></div>
        </article>
    </section>
}
