@page "/creds"

<PageTitle>@(IsAuthenticated ? "API Credentials" : "Sign In") - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <section id="credentials-unauthenticated" class="landing-signin" aria-labelledby="credentials-signin-heading">
        <div class="landing-signin__content stack-md">
            <h1 id="credentials-signin-heading">Sign in to manage API credentials</h1>
            <p class="section-copy">Create client credentials for automation, rotate secrets, and revoke old access without leaving the dashboard.</p>
            <p>
                <a id="credentials-login-link" href="/auth/login-discord" role="button" autofocus>Sign in with Discord</a>
            </p>
        </div>
    </section>
}
else
{
    <section id="credentials-page"
             class="credentials-page stack-lg"
             aria-label="Credentials">
        <article class="surface-card stack-md credentials-list-card">
            <header class="stack-sm">
                <div class="credentials-list-heading">
                    <h2 id="credentials-list-heading">Your API Credentials</h2>

                    <div class="credentials-list-actions">
                        <a id="credentials-create-open-button" href="/creds?modal=create" role="button">Create</a>
                    </div>
                </div>
            </header>

            @if (!string.IsNullOrWhiteSpace(PageError))
            {
                <p id="credentials-page-error" class="credentials-error" role="alert">@PageError</p>
            }

            <div class="credentials-table-wrapper">
                <table id="credentials-table" class="credentials-table">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Client ID</th>
                            <th scope="col">Created</th>
                            <th scope="col">Last Used</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="credentials-list">
                        @if (CredentialRows.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="credentials-table__empty">Create a credential to start exchanging for API tokens.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var credential in CredentialRows)
                            {
                                <tr>
                                    <td>@credential.Name</td>
                                    <td>
                                        <code class="credentials-table__client-id">@credential.ClientId</code>
                                    </td>
                                    <td>@FormatTimestamp(credential.CreatedAt)</td>
                                    <td>@FormatTimestamp(credential.LastUsedAt)</td>
                                    <td>
                                        <div class="credentials-table__actions">
                                            <a class="secondary outline" href="/creds?modal=regenerate&id=@credential.Id" role="button">Regenerate</a>
                                            <a class="contrast outline" href="/creds?modal=delete&id=@credential.Id" role="button">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </article>

        @if (ShowCreateModal)
        {
        <dialog id="credentials-create-modal" class="credentials-modal" open>
            <article>
                <header>
                    <a aria-label="Close" href="/creds" rel="prev"></a>
                    <h2 id="credentials-create-heading">Create a credential</h2>
                </header>

                <form id="credentials-create-form" class="stack-sm" method="post" action="/creds" @formname="create-credential" data-enhance>
                    <AntiforgeryToken />
                    <input type="hidden" name="Intent" value="create" />
                    <label for="credential-name-input">Name</label>
                    <input id="credential-name-input"
                           name="name"
                           type="text"
                           maxlength="100"
                           autocomplete="off"
                           placeholder="My api creds"
                           required
                           value="@CreateCredentialFormName" />
                    <p id="credential-name-help" class="credentials-help">1 to 100 characters. Control characters are not allowed.</p>

                    @if (!string.IsNullOrWhiteSpace(CreateCredentialError))
                    {
                        <p id="credentials-form-error" class="credentials-error" role="alert">@CreateCredentialError</p>
                    }

                    <footer class="credentials-modal__actions">
                        <a class="secondary" href="/creds" role="button">Cancel</a>
                        <button id="create-credential-button" type="submit">Create credential</button>
                    </footer>
                </form>
            </article>
        </dialog>
        }

        @if (ShowConfirmModal)
        {
        <dialog id="credentials-confirm-modal" class="credentials-modal" open>
            <article>
                <header>
                    <a aria-label="Close" href="/creds" rel="prev"></a>
                    <h2 id="credentials-confirm-title">@ConfirmTitle</h2>
                </header>

                <p id="credentials-confirm-message" class="credentials-copy">@ConfirmMessage</p>

                @if (!string.IsNullOrWhiteSpace(ConfirmError))
                {
                    <p id="credentials-confirm-error" class="credentials-error" role="alert">@ConfirmError</p>
                }

                <form method="post" action="/creds" @formname="confirm-credential" data-enhance>
                    <AntiforgeryToken />
                    <input type="hidden" name="Intent" value="confirm" />
                    <input type="hidden" name="Action" value="@CurrentConfirmActionName" />
                    <input type="hidden" name="CredentialId" value="@ConfirmCredentialId" />

                    <footer class="credentials-modal__actions">
                        <a class="secondary" href="/creds" role="button">Cancel</a>
                        <button type="submit" class="@(CurrentConfirmAction == PendingCredentialAction.Delete ? "contrast" : null)">@ConfirmButtonText</button>
                    </footer>
                </form>
            </article>
        </dialog>
        }

        @if (IssuedCredential is not null)
        {
        <dialog id="credentials-secret-modal" class="credentials-modal" open>
            <article>
                <header>
                    <a aria-label="Close" href="/creds" rel="prev"></a>
                    <h2 id="credentials-secret-heading">Copy this secret now</h2>
                </header>

                <p class="credentials-copy">You will only see this secret once. If you lose it, regenerate the secret for this credential.</p>

                <div class="credentials-secret-grid">
                    <div class="credentials-secret-block stack-sm">
                        <span class="credentials-label">Client ID</span>
                        <code id="credentials-issued-client-id">@IssuedCredential.Credential.ClientId</code>
                        <button type="button" class="secondary outline" data-copy-text="@IssuedCredential.Credential.ClientId" onclick="navigator.clipboard.writeText(this.dataset.copyText)">Copy client ID</button>
                    </div>

                    <div class="credentials-secret-block stack-sm">
                        <span class="credentials-label">Client Secret</span>
                        <code id="credentials-issued-client-secret">@IssuedCredential.ClientSecret</code>
                        <button type="button" class="secondary" data-copy-text="@IssuedCredential.ClientSecret" onclick="navigator.clipboard.writeText(this.dataset.copyText)">Copy client secret</button>
                    </div>
                </div>

                <footer class="credentials-modal__actions">
                    <a class="secondary" href="/creds" role="button">Close</a>
                </footer>
            </article>
        </dialog>
        }
    </section>
}
