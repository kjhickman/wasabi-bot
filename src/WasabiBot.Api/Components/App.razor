<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content="Sign in with Discord to manage your Wasabi Bot API access.">
    <base href="/" />
    <title>Wasabi Bot</title>
    <script>
        (function() {
            const storedTheme = localStorage.getItem('wasabi-theme') || 'system';
            const resolvedTheme = storedTheme === 'light' || storedTheme === 'dark'
                ? storedTheme
                : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

            document.documentElement.setAttribute('data-theme', resolvedTheme);
            document.documentElement.style.colorScheme = resolvedTheme;
        })();
    </script>
    <link rel="stylesheet" href="@Assets["pico.green.min.css"]"/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["WasabiBot.Api.styles.css"]"/>
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />

    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>
</html>
