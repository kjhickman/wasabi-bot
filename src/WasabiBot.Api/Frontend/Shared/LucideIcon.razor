@namespace WasabiBot.Api.Frontend.Shared

<svg xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 24 24"
     fill="@(Filled ? "currentColor" : "none")"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     class="@Class"
     aria-hidden="true">
    @switch (Name)
    {
        case LucideIconName.Heart:
            <path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09A6 6 0 0 0 7.5 3C4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3" />
            break;
        case LucideIconName.HeartPlus:
            <path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09A6 6 0 0 0 7.5 3C4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3" />
            <path d="M12 8v6" />
            <path d="M9 11h6" />
            break;
        case LucideIconName.HeartMinus:
            <path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09A6 6 0 0 0 7.5 3C4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3" />
            <path d="M9 11h6" />
            break;
        case LucideIconName.LogOut:
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <path d="m16 17 5-5-5-5" />
            <path d="M21 12H9" />
            break;
        case LucideIconName.Pause:
            <rect x="6" y="4" width="4" height="16" rx="1" />
            <rect x="14" y="4" width="4" height="16" rx="1" />
            break;
        case LucideIconName.Play:
            <path d="m6 4 14 8-14 8z" />
            break;
        case LucideIconName.SkipForward:
            <path d="m5 4 10 8-10 8z" />
            <path d="M19 5v14" />
            break;
        case LucideIconName.Stop:
            <rect x="6" y="6" width="12" height="12" rx="1" />
            break;
        case LucideIconName.ChevronUp:
            <path d="m18 15-6-6-6 6" />
            break;
        case LucideIconName.ChevronDown:
            <path d="m6 9 6 6 6-6" />
            break;
        case LucideIconName.Search:
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
            break;
        case LucideIconName.RefreshCw:
            <path d="M21 12a9 9 0 1 1-2.64-6.36" />
            <path d="M21 3v6h-6" />
            break;
        case LucideIconName.Trash2:
            <path d="M3 6h18" />
            <path d="M8 6V4h8v2" />
            <path d="M19 6l-1 14H6L5 6" />
            <path d="M10 11v6" />
            <path d="M14 11v6" />
            break;
        case LucideIconName.Disc3:
            <circle cx="12" cy="12" r="10" />
            <circle cx="12" cy="12" r="1" />
            <path d="M7 12a5 5 0 0 1 5-5" />
            <path d="M12 17a5 5 0 0 0 5-5" />
            break;
    }
</svg>

@code {
    [Parameter]
    public LucideIconName Name { get; set; }

    [Parameter]
    public string Class { get; set; } = string.Empty;

    [Parameter]
    public bool Filled { get; set; }
}
