@namespace WasabiBot.Api.Frontend.Shared

<section id="guild-access-required" class="flex min-h-[calc(100vh-14rem)] items-center justify-center" aria-labelledby="guild-access-required-heading">
    <div class="mx-auto max-w-2xl rounded-box border border-base-300 bg-base-100 p-5 text-center shadow-sm">
        <h1 id="guild-access-required-heading" class="text-3xl font-semibold tracking-tight md:text-4xl">Access requires a shared Discord server</h1>
        <p class="mt-4 text-base leading-7 text-base-content/70">You must be in a server with Wasabi Bot to access this site.</p>
        <form class="mt-6" action="/logout" method="post">
            <AntiforgeryToken />
            <button id="guild-access-required-logout" class="btn btn-primary" type="submit">Log out</button>
        </form>
    </div>
</section>
