@namespace WasabiBot.Api.Frontend.Modules.Music
@using WasabiBot.Api.Frontend.Shared
@using WasabiBot.Api.Features.Music

@if (IsLoadingFavorites)
{
    <p id="music-favorites-loading">Loading favorites...</p>
}
else
{
    <div class="music-results-grid">
        <section class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4" aria-labelledby="music-favorite-songs-heading">
            <p id="music-favorite-songs-heading" class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Songs</p>

            @if (Favorites.Songs.Count == 0)
            {
                <p id="music-favorite-songs-empty">No favorite songs yet.</p>
            }
            else
            {
                <ul id="music-favorite-songs" class="music-search-result-list">
                    @foreach (var favorite in Favorites.Songs)
                    {
                        <li class="music-search-result-item music-search-result-item--dense">
                            <div class="music-search-result-item__row">
                                <div class="music-search-result-item__content">
                                    @if (!string.IsNullOrWhiteSpace(favorite.ArtworkUrl))
                                    {
                                        <img class="music-search-result-item__artwork" src="@favorite.ArtworkUrl" alt="Artwork for @favorite.Title" />
                                    }
                                    else
                                    {
                                        <div class="music-artwork-placeholder music-search-result-item__artwork" aria-hidden="true">
                                            <LucideIcon Name="LucideIconName.Disc3" Class="size-7" />
                                        </div>
                                    }
                                    <div class="music-search-result-item__details">
                                        <strong>@favorite.Title</strong>
                                        <span>by @favorite.Subtitle</span>
                                        @if (!string.IsNullOrWhiteSpace(favorite.Song?.DurationText))
                                        {
                                            <div class="music-now-playing__meta-row">
                                                <span class="music-track-meta">@favorite.Song.DurationText</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="music-search-result-item__actions music-search-result-item__actions--right">
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnQueueFavorite.InvokeAsync(favorite)">Add to queue</button>
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnPlayFavoriteNext.InvokeAsync(favorite)">Play next</button>
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@IsSubmittingAction" @onclick="() => OnRemoveFavorite.InvokeAsync(favorite)">Remove</button>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>

        <section class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4" aria-labelledby="music-favorite-radio-heading">
            <p id="music-favorite-radio-heading" class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Radio</p>

            @if (Favorites.RadioStations.Count == 0)
            {
                <p id="music-favorite-radio-empty">No favorite radio stations yet.</p>
            }
            else
            {
                <ul id="music-favorite-radio" class="music-search-result-list">
                    @foreach (var favorite in Favorites.RadioStations)
                    {
                        <li class="music-search-result-item music-search-result-item--dense">
                            <div class="music-search-result-item__row">
                                <div class="music-search-result-item__content">
                                    @if (!string.IsNullOrWhiteSpace(favorite.ArtworkUrl))
                                    {
                                        <img class="music-search-result-item__artwork" src="@favorite.ArtworkUrl" alt="Artwork for @favorite.Title" />
                                    }
                                    else
                                    {
                                        <div class="music-artwork-placeholder music-search-result-item__artwork" aria-hidden="true">
                                            <LucideIcon Name="LucideIconName.Disc3" Class="size-7" />
                                        </div>
                                    }
                                    <div class="music-search-result-item__details">
                                        <strong>@favorite.Title</strong>
                                        @if (!string.IsNullOrWhiteSpace(favorite.Subtitle))
                                        {
                                            <span>@favorite.Subtitle</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(favorite.Radio?.Tags))
                                        {
                                            <span class="music-track-meta">@MusicDisplayFormatting.FormatStationTags(favorite.Radio.Tags)</span>
                                        }
                                    </div>
                                </div>
                                <div class="music-search-result-item__actions music-search-result-item__actions--right">
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnQueueFavorite.InvokeAsync(favorite)">Add to queue</button>
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnPlayFavoriteNext.InvokeAsync(favorite)">Play next</button>
                                    <button class="btn btn-sm btn-outline" type="button" disabled="@IsSubmittingAction" @onclick="() => OnRemoveFavorite.InvokeAsync(favorite)">Remove</button>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>
    </div>
}

@code {
    [Parameter]
    public bool IsLoadingFavorites { get; set; }

    [Parameter]
    public MusicFavoritesSnapshot Favorites { get; set; } = new([], []);

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public bool HasSharedSession { get; set; }

    [Parameter]
    public EventCallback<MusicFavoriteSummary> OnQueueFavorite { get; set; }

    [Parameter]
    public EventCallback<MusicFavoriteSummary> OnPlayFavoriteNext { get; set; }

    [Parameter]
    public EventCallback<MusicFavoriteSummary> OnRemoveFavorite { get; set; }
}
