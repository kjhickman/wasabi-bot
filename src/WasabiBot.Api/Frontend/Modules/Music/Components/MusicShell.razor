@namespace WasabiBot.Api.Frontend.Modules.Music
@implements IAsyncDisposable

<PageTitle>@PageTitleText - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <SignedOutPrompt SectionId="music-unauthenticated"
                     HeadingId="music-signin-heading"
                     Heading="Sign in to control music"
                     Description="Jump into a live player, queue tracks fast, and keep your library close at hand."
                     LinkId="music-login-link"
                     Href="@LoginHref" />
}
else if (!HasGuildAccess)
{
    <GuildAccessRequired />
}
else
{
    <section id="music-shell" class="-mt-2 space-y-6 md:-mt-4" aria-label="Music">
        <div>
            @if (!string.IsNullOrWhiteSpace(LoadError))
            {
                <article id="music-error" class="rounded-box border border-error/40 bg-error/10 px-4 py-3 text-sm text-error" aria-live="polite">
                    <strong>Dashboard unavailable</strong>
                    <span>@LoadError</span>
                </article>
            }
            else if (IsLoading)
            {
                <article id="music-loading" class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/80" aria-live="polite">
                    <strong>Loading music</strong>
                    <span>Checking the voice channel you're currently sharing with Wasabi Bot.</span>
                </article>
            }

            <div class="space-y-6">
                <div role="tablist" class="tabs tabs-box bg-base-200 p-1">
                    <a id="music-tab-live" href="/music" role="tab" class="@GetMusicTabClass(MusicPageKind.Live)">Live</a>
                    <a id="music-tab-search" href="/music/search" role="tab" class="@GetMusicTabClass(MusicPageKind.Search)">Search</a>
                    <a id="music-tab-favorites" href="/music/library" role="tab" class="@GetMusicTabClass(MusicPageKind.Library)">Favorites</a>
                    <a id="music-tab-top-played" href="/music/stats" role="tab" class="@GetMusicTabClass(MusicPageKind.Stats)">Top Played</a>
                </div>

                @switch (ActivePage)
                {
                    case MusicPageKind.Live:
                        <div id="music-tabpanel-live" role="tabpanel">
                            <MusicLivePage Session="Session"
                                           OnJoinUserChannel="JoinUserChannelAsync"
                                           IsSubmittingAction="IsSubmittingAction"
                                           OnTogglePause="TogglePauseAsync"
                                           OnSkip="SkipAsync"
                                           OnStop="StopAsync"
                                           OnRemoveQueueItem="RemoveQueueItemAsync"
                                           OnMoveQueueItemUp="MoveQueueItemUpAsync"
                                           OnMoveQueueItemDown="MoveQueueItemDownAsync"
                                           OnClearQueue="ClearQueueAsync" />
                        </div>
                        break;
                    case MusicPageKind.Search:
                        <div id="music-tabpanel-search" role="tabpanel">
                            <MusicSearchPage SearchQuery="@SearchQuery"
                                             SearchQueryChanged="OnSearchQueryChanged"
                                             IsSearching="IsSearching"
                                             HasSearchAttempt="@HasSearchAttempt"
                                             SearchError="@SearchError"
                                             SearchResults="SearchResults"
                                             IsSubmittingAction="IsSubmittingAction"
                                             HasSharedSession="@(Session?.UserChannel?.BotSharesChannel == true)"
                                             OnSearch="SearchAsync"
                                             OnQueueSong="QueueSongAsync"
                                             OnPlaySongNext="PlaySongNextAsync"
                                             OnSaveSongFavorite="SaveSongFavoriteAsync"
                                             OnQueueStation="QueueStationAsync"
                                             OnPlayStationNext="PlayStationNextAsync"
                                             OnSaveRadioFavorite="SaveRadioFavoriteAsync" />
                        </div>
                        break;
                    case MusicPageKind.Library:
                        <div id="music-tabpanel-favorites" role="tabpanel">
                            <MusicLibraryPage IsLoadingFavorites="IsLoadingFavorites"
                                              Favorites="Favorites"
                                              IsSubmittingAction="IsSubmittingAction"
                                              HasSharedSession="@(Session?.UserChannel?.BotSharesChannel == true)"
                                              OnQueueFavorite="QueueFavoriteAsync"
                                              OnPlayFavoriteNext="PlayFavoriteNextAsync"
                                              OnRemoveFavorite="RemoveFavoriteAsync" />
                        </div>
                        break;
                    case MusicPageKind.Stats:
                        <div id="music-tabpanel-top-played" role="tabpanel">
                            <MusicStatsPage Session="Session"
                                            IsLoadingMostPlayed="IsLoadingMostPlayed"
                                            MostPlayedTracks="MostPlayedTracks"
                                            IsSubmittingAction="IsSubmittingAction"
                                            HasSharedSession="@(Session?.UserChannel?.BotSharesChannel == true)"
                                            OnQueueTrack="QueueMostPlayedTrackAsync"
                                            OnPlayTrackNext="PlayMostPlayedTrackNextAsync"
                                            OnSaveTrackFavorite="SaveMostPlayedTrackFavoriteAsync" />
                        </div>
                        break;
                }
            </div>
        </div>
    </section>
}
