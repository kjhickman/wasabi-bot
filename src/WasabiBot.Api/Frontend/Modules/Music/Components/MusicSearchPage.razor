@namespace WasabiBot.Api.Frontend.Modules.Music
@using WasabiBot.Api.Frontend.Shared
@using WasabiBot.Api.Features.Music

<div class="music-page-stack">
    <form class="music-search-form music-search-form--hero" @onsubmit="OnSubmitAsync" @onsubmit:preventDefault>
        <label class="music-search-form__field" for="music-search-query">
            <span class="sr-only">Search query</span>
            <input id="music-search-query"
                   class="input input-bordered w-full"
                   type="search"
                   value="@SearchQuery"
                   placeholder="Search songs or radio stations"
                   @oninput="OnSearchInput" />
        </label>
        <button id="music-search-submit"
                class="btn btn-primary"
                type="submit"
                disabled="@IsSearching">
            <LucideIcon Name="LucideIconName.Search" Class="size-4" />
            <span>@(IsSearching ? "Searching..." : "Search")</span>
        </button>
    </form>

    @if (HasSearchAttempt && !string.IsNullOrWhiteSpace(SearchError))
    {
        <p id="music-search-error" class="rounded-box border border-error/40 bg-error/10 px-4 py-3 text-sm text-error">@SearchError</p>
    }

    @if (SearchResults is not null)
    {
        <div class="music-results-grid">
            <article class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4" aria-labelledby="music-song-results-heading">
                <p id="music-song-results-heading" class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Songs</p>

                @if (SearchResults.Songs.Count == 0)
                {
                    <p id="music-song-results-empty">No songs found.</p>
                }
                else
                {
                    <ul id="music-song-results" class="music-search-result-list">
                        @foreach (var song in SearchResults.Songs)
                        {
                            <li class="music-search-result-item music-search-result-item--dense">
                                <div class="music-search-result-item__row">
                                    <div class="music-search-result-item__content">
                                    @if (!string.IsNullOrWhiteSpace(song.ArtworkUrl))
                                    {
                                        <img class="music-search-result-item__artwork" src="@song.ArtworkUrl" alt="Artwork for @song.Title" />
                                    }
                                    else
                                    {
                                        <div class="music-artwork-placeholder music-search-result-item__artwork" aria-hidden="true">
                                            <LucideIcon Name="LucideIconName.Disc3" Class="size-7" />
                                        </div>
                                    }
                                        <div class="music-search-result-item__details">
                                            <strong>@song.Title</strong>
                                            <span>by @song.Author</span>
                                            <div class="music-now-playing__meta-row">
                                                <span class="music-track-meta">@song.DurationText</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="music-search-result-item__actions music-search-result-item__actions--right">
                                        <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnQueueSong.InvokeAsync(song)">Add to queue</button>
                                        <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnPlaySongNext.InvokeAsync(song)">Play next</button>
                                        <button class="btn btn-sm @(song.IsFavorited ? "btn-primary" : "btn-outline")" type="button" disabled="@IsSubmittingAction" @onclick="() => OnSaveSongFavorite.InvokeAsync(song)" aria-label="@(song.IsFavorited ? $"Remove {song.Title} from favorites" : $"Favorite {song.Title}")">
                                            <LucideIcon Name="@(song.IsFavorited ? LucideIconName.HeartMinus : LucideIconName.HeartPlus)" Class="size-4" />
                                        </button>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </article>

            <article class="rounded-box border border-base-300 bg-base-100 p-5 shadow-sm space-y-4" aria-labelledby="music-radio-results-heading">
                <p id="music-radio-results-heading" class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Radio</p>

                @if (SearchResults.Stations.Count == 0)
                {
                    <p id="music-radio-results-empty">No radio stations found.</p>
                }
                else
                {
                    <ul id="music-radio-results" class="music-search-result-list">
                        @foreach (var station in SearchResults.Stations)
                        {
                            <li class="music-search-result-item music-search-result-item--dense">
                                <div class="music-search-result-item__row">
                                    <div class="music-search-result-item__content">
                                    @if (!string.IsNullOrWhiteSpace(station.ArtworkUrl))
                                    {
                                        <img class="music-search-result-item__artwork" src="@station.ArtworkUrl" alt="Artwork for @station.Name" />
                                    }
                                    else
                                    {
                                        <div class="music-artwork-placeholder music-search-result-item__artwork" aria-hidden="true">
                                            <LucideIcon Name="LucideIconName.Disc3" Class="size-7" />
                                        </div>
                                    }
                                        <div class="music-search-result-item__details">
                                            <strong>@station.Name</strong>
                                            @if (!string.IsNullOrWhiteSpace(station.Country))
                                            {
                                                <span>@station.Country</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(station.Tags))
                                            {
                                                <span class="music-track-meta">@MusicDisplayFormatting.FormatStationTags(station.Tags)</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="music-search-result-item__actions music-search-result-item__actions--right">
                                        <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnQueueStation.InvokeAsync(station)">Add to queue</button>
                                        <button class="btn btn-sm btn-outline" type="button" disabled="@(IsSubmittingAction || !HasSharedSession)" @onclick="() => OnPlayStationNext.InvokeAsync(station)">Play next</button>
                                        <button class="btn btn-sm @(station.IsFavorited ? "btn-primary" : "btn-outline")" type="button" disabled="@IsSubmittingAction" @onclick="() => OnSaveRadioFavorite.InvokeAsync(station)" aria-label="@(station.IsFavorited ? $"Remove {station.Name} from favorites" : $"Favorite {station.Name}")">
                                            <LucideIcon Name="@(station.IsFavorited ? LucideIconName.HeartMinus : LucideIconName.HeartPlus)" Class="size-4" />
                                        </button>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </article>
        </div>
    }
</div>

@code {
    [Parameter]
    public string SearchQuery { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SearchQueryChanged { get; set; }

    [Parameter]
    public bool IsSearching { get; set; }

    [Parameter]
    public string? SearchError { get; set; }

    [Parameter]
    public bool HasSearchAttempt { get; set; }

    [Parameter]
    public MusicDashboardSearchResults? SearchResults { get; set; }

    [Parameter]
    public bool IsSubmittingAction { get; set; }

    [Parameter]
    public bool HasSharedSession { get; set; }

    [Parameter]
    public EventCallback OnSearch { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardSongSearchResult> OnQueueSong { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardSongSearchResult> OnPlaySongNext { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardSongSearchResult> OnSaveSongFavorite { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardRadioSearchResult> OnQueueStation { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardRadioSearchResult> OnPlayStationNext { get; set; }

    [Parameter]
    public EventCallback<MusicDashboardRadioSearchResult> OnSaveRadioFavorite { get; set; }

    private Task OnSearchInput(ChangeEventArgs args)
    {
        return SearchQueryChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private Task OnSubmitAsync()
    {
        return OnSearch.InvokeAsync();
    }
}
