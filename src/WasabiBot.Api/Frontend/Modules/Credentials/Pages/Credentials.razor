@namespace WasabiBot.Api.Frontend.Modules.Credentials
@page "/creds"
@attribute [Authorize(Policy = "DiscordGuildMember")]

<PageTitle>@(IsAuthenticated ? "API Credentials" : "Sign In") - Wasabi Bot</PageTitle>

@if (!IsAuthenticated)
{
    <SignedOutPrompt SectionId="credentials-unauthenticated"
                     HeadingId="credentials-signin-heading"
                     Heading="Sign in to manage API credentials"
                     Description="Create client credentials for automation, rotate secrets, and revoke old access without leaving the dashboard."
                     LinkId="credentials-login-link" />
}
else
{
    <section id="credentials-page" class="space-y-6" aria-label="Credentials">
        @if (!string.IsNullOrWhiteSpace(UrlReplacementPath))
        {
            <span hidden data-replace-url="@UrlReplacementPath"></span>
        }

        <CredentialsListCard CredentialRows="CredentialRows" PageError="@PageError" />

        @if (ShowCreateModal)
        {
            <CredentialsCreateDialog Model="CurrentCreateCredentialForm"
                                     CreateCredentialError="@CreateCredentialError"
                                     OnSubmit="HandleCreateSubmit" />
        }

        @if (ShowConfirmModal)
        {
            <CredentialsConfirmDialog Model="CurrentConfirmCredentialForm"
                                       ConfirmTitle="@ConfirmTitle"
                                       ConfirmMessage="@ConfirmMessage"
                                       ConfirmButtonText="@ConfirmButtonText"
                                      IsDeleteAction="@(CurrentConfirmAction == PendingCredentialAction.Delete)"
                                      ConfirmError="@ConfirmError"
                                      OnSubmit="HandleConfirmSubmit" />
        }

        @if (IssuedCredential is not null)
        {
            <IssuedCredentialDialog IssuedCredential="IssuedCredential" />
        }
    </section>
}
