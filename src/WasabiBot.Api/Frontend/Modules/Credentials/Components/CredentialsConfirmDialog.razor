@namespace WasabiBot.Api.Frontend.Modules.Credentials
<dialog id="credentials-confirm-modal" class="modal modal-open" open>
    <div class="modal-box space-y-4">
        <header class="space-y-2">
            <a class="link link-hover text-sm" href="/creds" rel="prev">Back</a>
            <h2 id="credentials-confirm-title">@ConfirmTitle</h2>
        </header>

        <p id="credentials-confirm-message" class="text-base leading-7 text-base-content/80">@ConfirmMessage</p>

        @if (!string.IsNullOrWhiteSpace(ConfirmError))
        {
            <p id="credentials-confirm-error" class="rounded-box border border-error/40 bg-error/10 px-4 py-3 text-sm text-error" role="alert">@ConfirmError</p>
        }

        <EditForm Model="Model" OnSubmit="OnSubmit" FormName="confirm-credential" Enhance>
            <footer class="modal-action">
                <a class="btn btn-ghost" href="/creds">Cancel</a>
                <button class="btn @(IsDeleteAction ? "btn-error" : "btn-primary")" type="submit">@ConfirmButtonText</button>
            </footer>
        </EditForm>
    </div>
</dialog>

@code {
    [Parameter, EditorRequired]
    public required CredentialsConfirmCredentialFormInput Model { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmTitle { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmMessage { get; set; }

    [Parameter, EditorRequired]
    public required string ConfirmButtonText { get; set; }

    [Parameter]
    public bool IsDeleteAction { get; set; }

    [Parameter]
    public string? ConfirmError { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }
}
