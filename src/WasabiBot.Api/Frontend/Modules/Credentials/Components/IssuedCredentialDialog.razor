@namespace WasabiBot.Api.Frontend.Modules.Credentials
@using WasabiBot.Api.Infrastructure.Auth

<dialog id="credentials-secret-modal" class="modal modal-open" open>
    <div class="modal-box space-y-4">
        <header class="space-y-2">
            <a class="link link-hover text-sm" href="/creds" rel="prev">Back</a>
            <h2 id="credentials-secret-heading">Copy this secret now</h2>
        </header>

        <p class="text-base leading-7 text-base-content/80">You will only see this secret once. If you lose it, regenerate the secret for this credential.</p>

        <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-box border border-base-300 bg-base-200 p-4">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Client ID</span>
                <code id="credentials-issued-client-id" class="mt-2 block whitespace-pre-wrap break-all rounded-box bg-base-100 px-3 py-2 text-sm">@IssuedCredential.Credential.ClientId</code>
                <button type="button"
                        class="btn btn-outline btn-sm mt-3"
                        data-copy-button
                        data-copy-label="Copy client ID"
                        data-copy-text="@IssuedCredential.Credential.ClientId">Copy client ID</button>
            </div>

            <div class="rounded-box border border-base-300 bg-base-200 p-4">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Client Secret</span>
                <code id="credentials-issued-client-secret" class="mt-2 block whitespace-pre-wrap break-all rounded-box bg-base-100 px-3 py-2 text-sm">@IssuedCredential.ClientSecret</code>
                <button type="button"
                        class="btn btn-outline btn-sm mt-3"
                        data-copy-button
                        data-copy-label="Copy client secret"
                        data-copy-text="@IssuedCredential.ClientSecret">Copy client secret</button>
            </div>
        </div>

        <footer class="modal-action">
            <a class="btn btn-primary" href="/creds">Close</a>
        </footer>
    </div>
</dialog>

@code {
    [Parameter, EditorRequired]
    public required ApiCredentialIssueResult IssuedCredential { get; set; }
}
