{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft*": "Warning",
      "System.Net.Http*": "Warning",
      "MassTransit": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
